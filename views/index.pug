extends layout  

block metadata 
        title user
        script(src="https://unpkg.com/@tailwindcss/browser@4")
        link(rel="stylesheet", href="/css/style.css")

block contenido
        div(class='relative h-screen flex items-center justify-center bg-gray-100')
                div(class='bg-red-600 w-[90%] h-32 rounded-3xl shadow-lg flex items-center relative px-10')
                    p(class='font-bold text-xl mr-6') hola
                    img(src="/img/camalardo.jpg", alt="", class='absolute left-10 top-1/2 -translate-y-1/2 z-20 w-48 h-48 object-cover rounded-2xl shadow-2xl border-4 border-white')
                    div(class='flex items-center ml-56 text-white')
                        div(class='flex flex-col') 
                            p(class='font-bold text-2xl') Titulo 
                            p(class='text-sm opacity-90') Descripcion
                            p(class='text-xs italic mt-1') Comentarios
                            section(class="max-w-5xl mx-auto py-10 flex flex-col gap-8")
        main                         
                a(href="/publicar" class="bg-linear-to-b from-[#60b035] to-[#3a751c] hover:from-[#72cb3f] hover:to-[#468e22] text-white font-bold italic text-lg px-6 h-12 flex items-center shadow-lg transition-all rounded-full fixed bottom-6 right-6 md:static md:rounded-lg")
                span(class='drop-shadow-[1px_1px_1px_rgba(0,0,0,0.8)]') + Subir foto
