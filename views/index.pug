extends layout

block metadata 
        title user
        script(src="https://unpkg.com/@tailwindcss/browser@4")
        link(rel="stylesheet" href="/css/style.css")
        link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=arrow_circle_up")


block contenido
        main(class='mx-auto p-4 ')
        if publicaciones && publicaciones.length > 0
                div(class='flex flex-col gap-8 m-7 ')
                        each publis in publicaciones
                                div(class='bg-white/70 my-9 backdrop-blur-md rounded-3xl shadow-2xl border border-white/40 flex overflow-hidden w-fit mx-auto transition-transform hover:scale-[1.01]')
                                        div(class='w-16 shrink-0 flex flex-col items-center py-6 border-r border-gray-200/50 bg-gray-50/30')
                                                div(class="w-10 h-10 bg-black rounded-lg flex items-center justify-center text-white font-black mb-10 shadow-md")
                                                        p(class="vertical-text font-bold text-gray-600 tracking-widest text-xs uppercase" style="writing-mode: vertical-rl; transform: rotate(180deg)") 
                                                        | #{publis.Usuario.foto_de_perfil}
                                        div(class=" bg-gray-200 overflow-hidden relative group h-auto w-[50vw] ")
                                                if publis.imagenes && publis.imagenes.length > 0
                                                        div(class="flex transition-transform duration-500 ease-in-out h-full" id=`slider-${publis.id}`)
                                                                each image in publis.imagenes
                                                                        div(class="min-w-full h-full flex items-center justify-center bg-black/5")
                                                                                img(src= image class=" w-auto h-auto object-contain max-w-[50vw] max-h-[70vh]")
                                                        if publis.imagenes && publis.imagenes.length > 1
                                                                button(class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity z-10" onclick=`cambiarFoto('${publis.id}', -1)`) 
                                                                                i(class="fa-solid fa-chevron-left")
                                                                button(class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity z-10" onclick=`cambiarFoto('${publis.id}', 1)`) 
                                                                                i(class="fa-solid fa-chevron-right")
                                        div(class="shrink-0 w-70 p-6 flex flex-col justify-between bg-white/40")
                                                div 
                                                        h3(class='font-bold text-xl text-blue-900 drop-shadow-sm')= publis.title
                                                        p(class="text-sm text-gray-700 mt-2 leading-relaxed")= publis.description
                                                p Comentarios
                                                div(class='max-h-80 overflow-y-auto  space-y-2 mb-3 pr-1 [&::-webkit-scrollbar]:w-1 [&::-webkit-scrollbar-track]:bg-transparent [&::-webkit-scrollbar-thumb]:bg-black/30 [&::-webkit-scrollbar-thumb]:rounded-full hover:[&::-webkit-scrollbar-thumb]:bg-blue-400"')
                                                        
                                                        div(id=`lista-comentarios-${publis.ImagenId}` class='bg-white/40 rounded')
                                                                if publis.comentarios && publis.comentarios.length > 0
                                                                        each comentario in publis.comentarios
                                                                                div(class=' p-2  border-b border-black/20')
                                                                                        p nombreUser:
                                                                                        span= comentario.texto
                                                                else    
                                                                        p(class='text-gray-600') Se el primero en comentar...
                                                div
                                                        form.form_comentario(class='flex items-center bg-white/40 rounded p-2')
                                                                input(type="hidden", name="ImagenId" value=publis.ImagenId)
                                                                input(type="text" placeholder='Escribe un comentario..' name="texto" class='flex-1 border bg-white/40 rounded pl-2')
                                                                button(type='submit'  class ='cursor-pointer flex-row') 
                                                                        i(class="fa-solid fa-circle-arrow-up text-3xl text-blue-500/90 border-blue-600 hover:text-blue-500")
                                                                        
                                                div(class="flex flex-col gap-4")
                                                        div(class="flex justify-around text-2xl text-gray-600")
                                                            button(class="hover:text-red-500 transition-colors cursor-pointer") corazon
                                                            button(class="hover:text-blue-500 transition-colors cursor-pointer") nose
                                                            button(class="hover:text-green-500 transition-colors cursor-pointer") nose

                                                

        button#btn_abrir(type="button" class='group fixed bottom-8 right-8 z-40 bg-green-400/20 border-green-600/50  border py-3 px-4 rounded-full text-black font-bold text-xl shadow-2xl transition-all duration-500 hover:scale-105 cursor-pointer flex items-center gap-0 hover:gap-2') 
                | + 
                span(class='max-w-0 inline-block overflow-hidden opacity-0 transition-all duration-500 ease-in-out group-hover:max-w-xs group-hover:opacity-100 text-sm font-semibold tracking-wide whitespace-nowrap') Nueva Publicacion
        include mixins/subirPubli.pug

        script. 
                const subir = document.getElementById('bg_subir');
                const btnAbrir = document.getElementById('btn_abrir');
                const btnCerrar = document.getElementById('btn_cerrar');

                if(btnAbrir && subir){
                   btnAbrir.addEventListener('click', ()=>{
                        subir.classList.remove('hidden');
                   });
                }
                if(btnCerrar && subir){
                   btnCerrar.addEventListener('click', ()=>{
                        subir.classList.add('hidden');
                   });
                }

                document.querySelectorAll('.form_comentario').forEach(form => {
                        form.addEventListener('submit', async (e) => {
                            e.preventDefault(); 
                            const inputTexto = form.querySelector('input[name="texto"]');
                            const imagenId = form.querySelector('input[name="ImagenId"]').value;
                        if (!inputTexto.value.trim()) return;

                    const response = await fetch('/comentarios/new', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            ImagenId: imagenId,
                            texto: inputTexto.value
                        })
                    });

                    if (response.ok) {
                        const nuevoComentario = await response.json();

                        const lista = document.getElementById(`lista-comentarios-${imagenId}`);
                        const nuevoDiv = document.createElement('div');
                        nuevoDiv.className = 'bg-white p-2 rounded-lg mb-2';
                        nuevoDiv.innerHTML = `${nuevoComentario.comentario.texto}`;
                        lista.appendChild(nuevoDiv);

                        inputTexto.value = '';
                    }
                });
            });
            const carruselImgs = {};
            function cambiarFoto(publiId, dir){
                const slider = document.getElementById(`slider-${publiId}`);
                const limite = slider.children.length;
                if (carruselImgs[publiId] === undefined) carruselImgs[publiId] = 0;
                
                carruselImgs[publiId] += dir;
                if (carruselImgs[publiId] >= limite) carruselImgs[publiId] = 0;
                if (carruselImgs[publiId] < 0) carruselImgs[publiId] = limite - 1;
                
                slider.style.transform = `translateX(-${carruselImgs[publiId] * 100}%)`;
            }
