mixin navbar(usuario)
    nav(class='sticky top-0 z-50 bg-white/15 backdrop-blur-md border-b border-white/20 shadow-lg flex justify-between items-center p-4')
        a(href="/index" class="text-2xl font-black italic tracking-tighter text-white drop-shadow-md text-right") Fotaza
        
        ul(class='flex gap-4 m-0 list-none items-center')
            li
                a(href='/' class='text-white hover:bg-white/20 px-3 py-1 rounded transition-all') Inicio
            
            if usuario
                li 
                    a(href='/explorar' class='text-white hover:bg-white/20 px-3 py-1 rounded transition-all') Explorar
                li 
                    a(href='/profile' class='text-white hover:bg-white/20 px-3 py-1 rounded transition-all font-bold bg-white/10') Mi Perfil
            else
                li 
                    a(href='/iniciosSesion' class='text-white hover:bg-white/20 px-3 py-1 rounded transition-all font-bold') Iniciar Sesión