block contenido
        div#bg_subir(class="fixed inset-0 backdrop-blur-sm z-50 flex items-center justify-center p-4  bg-black/30 hidden")

            div(class="relative w-full max-w-2xl")

                button#btn_cerrar(class="absolute top-4 right-4 text-white/60 hover:text-red-500 hover:font-bold text-xl cursor-pointer z-10 hover:bg-white/10 rounded-full w-10 h-10 items-center justify-center") ✕

                form(action="/p" method="POST" autocomplete='off'  class='flex flex-col gap-2.5 m-auto p-10 md:p-20 bg-blue-900/20 backdrop-blur-xl border-2 border-white/10 rounded-xl shadow-2xl')

                    input(type="text" name="titulo"  placeholder="Título de la publicacion" class='border-white/50 border-2 rounded-xs p-1 text-white peer w-full bg-transparent py-2 outline-none focus:border-white transition-colors')

                    textarea(name="descripcion" placeholder="Descripción" class='border-white/50 border-2 rounded-xs p-1 text-white peer w-full bg-transparent py-2 outline-none focus:border-white transition-colors')

                    p(class='text-xl text-white/80') Comentarios 
                    input(type="checkbox", name="")


                    input#img(type="file" name="img" multiple class='text-white file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-white/10 file:text-white hover:file:bg-white/20 file:cursor-pointer') 
                div#container_preview(class='flex flex-wrap gap-4 mt-4')
                    img#preview(src="", alt="preview" class="hidden w-50 h-50 object-cover rounded-lg border-2 border-white/30 mt-4 shadow-lg transition-all")
                    textarea#imgBase64(name="imgBase64" hidden) 

                    input#subir(type='submit' value='Publicar' class='w-full cursor-pointer border-2 border-white/30 rounded-md py-3 text-white bg-white/10 backdrop-blur-md hover:text-green-600/80 hover:bg-green-400/20 hover:border-green-600/50 transition-all text-xl font-bold tracking-widest shadow-lg mt-4')

        script. 
            const fileInput = document.getElementById('img');
            const imgBase64 = document.getElementById('imgBase64');
            const preview = document.getElementById('preview');
            const previewContainer = document.getElementById('container_preview');

            fileInput.addEventListener('change', (e) =>{
                const file = e.target.files;
                for (let i = 0 ; i < file.length; i++){
                    const files= file[i];
                    const reader = new FileReader();
                    reader.onload = () => {
                    const divWrapper = document.createElement('div');
                    divWrapper.className = 'relative inline-block mt-4';
                    const imgNode = document.createElement('img');
                    imgNode.src = reader.result;
                    imgNode.className = 'w-32 max-h-32 object-cover rounded-lg border-2 border-white/30 shadow-lg';
                    const hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'imgBase64'; 
                    hiddenInput.value = reader.result;
                    const btnDelete = document.createElement('button');
                    btnDelete.type = 'button';
                    btnDelete.innerHTML = '✕';
                    btnDelete.className = 'absolute -top-2 -right-2 bg-white/40 text-red-500 hover:text-white hover:font-bold text-xl cursor-pointer z-10 hover:bg-red-500  rounded-full w-6 h-6 flex items-center justify-center font-bold shadow-md cursor-pointer transition-colors';
                    btnDelete.onclick = () => {
                            divWrapper.remove();
                        };
                    
                    divWrapper.appendChild(imgNode);
                    divWrapper.appendChild(hiddenInput);
                    divWrapper.appendChild(btnDelete);

                    previewContainer.appendChild(divWrapper);
                };
                    reader.readAsDataURL(files);
                }
                fileInput.value = '';
            });