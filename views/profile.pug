extends layout 

block metadata
        link(rel="stylesheet", href="/css/style.css")
        script(src="https://unpkg.com/@tailwindcss/browser@4")
block contenido 
                div(class=' h-80 max-w-7xl mx-auto  flex rounded-b-xl bg-blue-700/30 backdrop-blur-md border-b border-r border-l border-white/70 shadow-lg text-white ')

                        div(class='flex  items-center gap-4 flex-1 p-8')
                                if usuario.foto_de_perfil
                                        img(src="/img/camalardo.jpg", alt="" class='rounded-full w-24 h-24 object-cover')
                                else 
                                        img(src="/img/camalardo.jpg" class='rounded-full w-60 h-60 bg-amber-600  ')
                                div(class='flex flex-col gap-1')
                                        h2(class='text-3xl font-bold ') @username
                                        span(class='text-xl font-medium') 12
                                        | Seguidores
                                        span(class='text-xl font-medium') 33
                                        | Siguiendo
                        div(class='flex flex-col gap-4 flex-1 justify-between pt-5')
                                div(class='flex flex-col')
                                        h3(class='text-xl uppercase tracking-wider') sobre mi
                                        if usuario.descrpcion
                                                p(class='')=  usuario.descrip
                                        else 
                                                p(class='') usuario aun no agrego descripcion
                                div(class='flex flex-col items-center bg-white/30 w-80 mx-auto p-6 rounded-t-2xl')
                                        h3 Promedio valoraciones
                                        div(class='flex items-center pt-3')
                                                span= usuario.promedio || '0.0'
                                                span estrellas 
                main(class='max-w-7xl mx-auto p-4 mt-8')
                        if publicaciones && publicaciones.length > 0
                                div(class='grid grid-cols-1 md:grid-cols-2 gap-8')
                                        each publis in publicaciones
                                                div(class='bg-white/70 backdrop-blur-md rounded-3xl shadow-2xl border border-white/40 flex flex-col xl:flex-row overflow-hidden w-full transition-transform hover:scale-[1.01]')
                                                                div(class='w-16 shrink-0 flex flex-col items-center py-6 border-r border-gray-200/50 bg-gray-50/30')
                                                                div(class="w-10 h-10 bg-black rounded-lg flex items-center justify-center text-white font-black mb-10 shadow-md")
                                                                        p(class="vertical-text font-bold text-gray-600 tracking-widest text-xs uppercase" style="writing-mode: vertical-rl; transform: rotate(180deg)") 
                                                                        = publis.Usuario.foto_de_perfil
                                                div(class="bg-gray-200 overflow-hidden relative group flex-1 min-h-[40vh]")
                                                                if publis.imagenes && publis.imagenes.length > 0
                                                                        div(class="flex transition-transform duration-500 ease-in-out h-full" id=`slider-${publis.id}`)
                                                                                each image in publis.imagenes
                                                                                        div(class="min-w-full h-full flex items-center justify-center bg-black/5")
                                                                                                img(src= image class="w-full h-full object-contain max-h-[60vh]")
                                                                        if publis.imagenes && publis.imagenes.length > 1
                                                                                button(class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity z-10" onclick=`cambiarFoto('${publis.id}', -1)`) 
                                                                                        i(class="fa-solid fa-chevron-left")
                                                                                button(class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/30 hover:bg-black/50 text-white p-2 rounded-full cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity z-10" onclick=`cambiarFoto('${publis.id}', 1)`) 
                                                                                        i(class="fa-solid fa-chevron-right")
                                                div(class="shrink-0 w-70 p-6 flex flex-col justify-between bg-white/40 text-black")
                                                                div 
                                                                        h3(class='font-bold text-xl text-blue-900 drop-shadow-sm')= publis.title
                                                                        p(class="text-sm text-gray-700 mt-2 leading-relaxed")= publis.descriptio
                                                                if publis.comments_allowed
                                                                        p(class="font-semibold text-gray-800 mt-4 mb-2") Comentarios
                                                                        div(class='max-h-60 overflow-y-auto space-y-2 mb-3 pr-1 [&::-webkit-scrollbar]:w-1 [&::-webkit-scrollbar-track]:bg-transparent [&::-webkit-scrollbar-thumb]:bg-black/30 [&::-webkit-scrollbar-thumb]:rounded-full hover:[&::-webkit-scrollbar-thumb]:bg-blue-400')
                                                                                div(id=`lista-comentarios-${publis.ImagenId}` class='bg-white/40 rounded')
                                                                                        if publis.comentarios && publis.comentarios.length > 0
                                                                                                each comentario in publis.comentarios
                                                                                                        div(class='p-2 border-b border-black/20')
                                                                                                                p(class='text-blue-500 font-bold')= comentario.Usuario
                                                                                                                span(class="text-gray-800")= comentario.texto
                                                                                        else    
                                                                                                p(class='text-gray-600 text-sm') Sé el primero en comentar..
                                                                        form.form_comentario(class='flex items-center bg-white/40 rounded p-2')
                                                                                input(type="hidden", name="ImagenId" value=publis.ImagenId)
                                                                                input(type="text" placeholder='Escribe un comentario..' name="texto" class='flex-1 border-none bg-transparent outline-none pl-2 text-gray-800 placeholder-gray-600')
                                                                                button(type='submit' class='cursor-pointer flex-row ml-2') 
                                                                                        i(class="fa-solid fa-circle-arrow-up text-3xl text-blue-500/90 hover:text-blue-600 transition-colors")
                                                                else 
                                                                        p(class="text-gray-500 italic mt-4") Comentarios desactivado
                                                                div(class="flex flex-col gap-4 mt-4")
                                                                        div(class="flex justify-around text-2xl text-gray-600")
                                                                                button(class="hover:text-red-500 transition-colors cursor-pointer")
                                                                                        i(class="fa-regular fa-heart")
                                                                                button(class="hover:text-blue-500 transition-colors cursor-pointer")
                                                                                        i(class="fa-regular fa-comment")
                                                                                button(class="hover:text-green-500 transition-colors cursor-pointer")
                                                                                        i(class="fa-solid fa-share-nodes")
                        else 
                                div(class="bg-red-500 text-white p-6 rounded-xl text-center shadow-lg")
                                        p nose