        script. 
            document.addEventListener("DOMContentLoaded", ()=>{
                const slider = document.getElementById("slider");

                if(slider){
                    let indice = 0;
                    setInterval(()=>{
                        indice = (indice +1) % slider.children.length;
                        slider.style.transform = `translateX(-${indice * 100}%)`;
                    }, 3000);
                }
            })